# --- Результаты работы программы ---
# Игнорируем всю папку result и её подпапки (XTEA, ElGamal и т.д.)
# Игнорируем всё содержимое папки result
src/result/XTEA/**/*
# НО НЕ ИГНОРИРУЕМ файлы .gitkeep (это позволит папкам отобразиться в GitHub)
!src/result/**/no_read.txt
!src/result/no_read.txt
# --- Бинарные файлы и сборка ---
# Игнорируем скомпилированное основное приложение
src/app

# Игнорируем динамические библиотеки (.so файлы) в любых папках
*.so
src/code/XTEA/*.so
src/code/ElGamal/*.so

# Игнорируем объектные файлы
*.o

# --- Временные файлы редакторов ---
# Если используешь VS Code
.vscode/
*.log

# Файлы операционной системы
.DS_Store
Thumbs.db
